# Normalize all text files in the repository
* text=auto

# Keep Unix-style line endings for source/docs/scripts
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Keep Windows script line endings if such files are added later
*.bat text eol=crlf
*.cmd text eol=crlf

# Prevent Git from altering binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary
